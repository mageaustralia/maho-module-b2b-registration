{
    "name": "mageaustralia/maho-module-b2b-registration",
    "description": "Trade-account registration flow for Maho 26.5+: turns a Custom Forms trade-application submission into a pending customer (mapping fields onto customer attributes), drops it in the approval queue, and fires an event for downstream company/ERP wiring.",
    "type": "maho-module",
    "license": "OSL-3.0",
    "authors": [
        {
            "name": "MageAustralia",
            "email": "dev@mageaustralia.com.au"
        }
    ],
    "keywords": [
        "maho",
        "openmage",
        "magento",
        "b2b",
        "trade-account",
        "registration"
    ],
    "homepage": "https://github.com/mageaustralia/maho-module-b2b-registration",
    "require": {
        "php": "^8.3",
        "mahocommerce/maho": "^26.5",
        "mageaustralia/maho-module-custom-forms": "^1.0",
        "mageaustralia/maho-module-customer-approval": "^1.0"
    },
    "autoload": {
        "psr-0": {
            "MageAustralia_B2bRegistration": "app/code/community"
        }
    },
    "extra": {
        "maho-module": {
            "module-xml": "app/etc/modules/MageAustralia_B2bRegistration.xml"
        }
    }
}
